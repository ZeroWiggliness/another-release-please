{
  "provider": "github",
  "release": {
    "prerelease": false,
    "releaseBranchPrefix": "feature/",
    "maxReleases": 10,
    "maxCommits": 100,
    "includeChores": false
  },
  "version": "v0.1.2",
  "versionPrefix": "v",
  "manifests": [
    {
      "path": ".",
      "type": "node",
      "version": "0.1.2"
    },
    {
      "path": ".",
      "type": "custom",
      "version": "v0.1.2",
      "versionPrefix": "v",
      "files": [
        {
          "path": "README.md",
          "filetype": "text",
          "versionPatterns": [
            "https://img\\.shields\\.io/badge/version-([^-]+)-blue"
          ]
        }
      ]
    }
  ]
}
